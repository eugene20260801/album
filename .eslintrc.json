{
  "root": true,
  "env": {
    "es2021": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "overrides": [
    {
      "files": ["album-frontend/**/*.{js,ts,jsx,tsx}"],
      "extends": ["plugin:react/recommended"],
      "parserOptions": {
        "ecmaFeatures": {
          "jsx": true
        },
        "ecmaVersion": 2021,
        "sourceType": "module"
      },
      "rules": {}
    },
    {
      "files": ["backend/**/*.{js,ts}"],
      "env": { "node": true },
      "rules": {}
    }
  ]
}