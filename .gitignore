# Node.js dependencies (ignore for both frontend and backend)
node_modules/
album-backend/node_modules/
album-frontend/node_modules/

# Next.js build output
.next/
album-frontend/.next/

# TypeScript build output
dist/
build/
album-backend/dist/
album-frontend/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
album-backend/.env
album-frontend/.env

# Docker artifacts
docker-compose.override.yml
*.dockerfile
docker/*.log

# OS generated files
.DS_Store
Thumbs.db

# Editor / IDE settings
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Husky & lint-staged
.husky/

# Ignore other temporary files
tmp/
cache/
/generated/prisma
